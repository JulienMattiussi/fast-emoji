{
  "name": "fast-emoji",
  "version": "1.0.0",
  "author": "YavaDeus",
  "private": true,
  "description": "Chrome extension to quickly copy emojis to clipboard",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.24.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
